# Terraform files must keep LF line endings regardless of platform autocrlf settings
*.tf             text eol=lf
*.tfvars         text eol=lf
*.tfvars.example text eol=lf
*.tfvars.json    text eol=lf

# Shell scripts and bootstrap env templates must keep LF line endings
*.sh             text eol=lf
*.env.example    text eol=lf
