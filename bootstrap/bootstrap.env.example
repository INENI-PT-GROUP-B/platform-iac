# Copy this file to bootstrap.env and adjust the values for your environment.
# bootstrap.env is gitignored and must never be committed.
#
# These values are the single source of truth: bootstrap.sh exports them as
# TF_VAR_* so Terraform reads the same values. No terraform.tfvars is needed.

# GCP project that owns the platform resources.
GCP_PROJECT_ID=dotted-axle-495612-f4

# Default GCP region for resources.
GCP_REGION=europe-west1

# Zone for zonal resources (the GKE cluster). Must be inside GCP_REGION.
GCP_ZONE=europe-west1-b

# Location for the Terraform remote-state bucket (gs://${GCP_PROJECT_ID}-tfstate).
TFSTATE_BUCKET_LOCATION=europe-west1

# Optional: GitHub PAT for seeding the shared GHCR pull secret into Google
# Secret Manager (bootstrap Phase 1a). Required scope: `read:packages` only.
# When unset, Phase 1a is skipped with a warn and Day-1 bring-up still succeeds;
# tenant frontend image pulls then fail at runtime until this is set and
# bootstrap.sh re-runs (idempotent — adds a new SecretVersion only on rotation).
# Username is informational for ghcr.io PAT auth and defaults to the org slug.
# GHCR_TOKEN=ghp_...
# GHCR_USERNAME=ineni-pt-group-b

# Optional: Grafana admin credentials for seeding the GSM entry `grafana-admin`
# consumed by the monitoring stack (bootstrap Phase 1b). When unset, Phase 1b
# is skipped with a warn and Day-1 bring-up still succeeds; Grafana stays
# unavailable (Pod stuck waiting for the admin Secret) until this is set and
# bootstrap.sh re-runs (idempotent — adds a new SecretVersion only on rotation).
# Username defaults to `admin`, matching the chart-default expectation; pick a
# strong random password — the chart-default `prom-operator` is unacceptable
# for an internet-exposed host.
# GRAFANA_ADMIN_PASSWORD=<random>
# GRAFANA_ADMIN_USER=admin
