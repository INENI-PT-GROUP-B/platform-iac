# Copy this file to bootstrap.env and adjust the values for your environment.
# bootstrap.env is gitignored and must never be committed.
#
# These values are the single source of truth: bootstrap.sh exports them as
# TF_VAR_* so Terraform reads the same values. No terraform.tfvars is needed.

# GCP project that owns the platform resources.
GCP_PROJECT_ID=dotted-axle-495612-f4

# Default GCP region for resources.
GCP_REGION=europe-west1

# Zone for zonal resources (the GKE cluster). Must be inside GCP_REGION.
GCP_ZONE=europe-west1-b

# Location for the Terraform remote-state bucket (gs://${GCP_PROJECT_ID}-tfstate).
TFSTATE_BUCKET_LOCATION=europe-west1
